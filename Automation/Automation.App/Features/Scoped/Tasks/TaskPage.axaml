<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tasks="clr-namespace:Automation.App.Features.Scoped.Tasks"
             xmlns:components="clr-namespace:Automation.App.Features.Scoped.Components"
             x:DataType="tasks:TaskVm"
             x:Class="Automation.App.Features.Scoped.Tasks.TaskPage">
    <StackPanel Margin="4" Spacing="8">
        <components:ElementHeader />
        <TextBlock Classes="Muted" Text="The task editor will be displayed here." />
    </StackPanel>
</UserControl>
