<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tasks="clr-namespace:Automation.App.Features.Scoped.Tasks"
             xmlns:components="clr-namespace:Automation.App.Features.Scoped.Components"
             xmlns:packagesComponents="clr-namespace:Automation.App.Features.Packages.Components"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:shadUi="clr-namespace:ShadUI;assembly=ShadUI"
             x:DataType="tasks:TaskVm"
             x:Class="Automation.App.Features.Scoped.Tasks.TaskPage">
    <Grid Margin="4" RowSpacing="8" RowDefinitions="auto *">
        <components:ElementHeader />
        <TabControl Grid.Row="1">
            <TabControl.Items>
                <TabItem Header="Package">
                    <Panel>
                        <Border IsVisible="{Binding WithoutTarget}"
                                BorderBrush="{DynamicResource WarningColor20}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource MdCornerRadius}"
                                MinHeight="128">
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Classes="LucideIcon"
                                               Foreground="{DynamicResource WarningColor}"
                                               VerticalAlignment="Center"
                                               Text="{x:Static fonts:LucideIconFont.AlertTriangle}" />
                                    <TextBlock Text="No target"
                                               Foreground="{DynamicResource WarningColor60}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Classes="Primary" HorizontalAlignment="Center" Content="Select" Command="{Binding SelectTargetCommand}" />
                            </StackPanel>
                        </Border>
                        <Panel
                            IsVisible="{Binding !WithoutTarget}">
                            <packagesComponents:TaskTargetSummary DataContext="{Binding Task.Target}" />
                            <Button
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Classes="DestructiveIcon"
                                CornerRadius="{StaticResource FullCornerRadius}">
                                <shadUi:ButtonAssist.Icon>
                                    <TextBlock
                                        Classes="LucideIcon"
                                        Margin="0,8"
                                        Text="{x:Static fonts:LucideIconFont.Trash}" />
                                </shadUi:ButtonAssist.Icon>
                            </Button>
                        </Panel>
                    </Panel>
                </TabItem>
                <TabItem Header="History">
                    <TextBlock Classes="Muted" Text="History of the task goes there." />
                </TabItem>
            </TabControl.Items>
        </TabControl>
    </Grid>
</UserControl>