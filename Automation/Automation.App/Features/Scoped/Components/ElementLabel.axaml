<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Automation.App.Converters"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:scoped="clr-namespace:Automation.App.Features.Scoped"
             x:DataType="scoped:ScopedVm"
             x:Class="Automation.App.Features.Scoped.Components.ElementLabel">
    <Design.DataContext>
        <scoped:ScopedVmDesign />
    </Design.DataContext>
    <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Classes="LucideIcon"
                   Foreground="{Binding Metadata.Color, Converter={x:Static converters:StringToBrush.Instance}}"
                   Text="{Binding Metadata, Converter={x:Static converters:ScopedTypeConverters.ToIcon}}" />
        <TextBlock VerticalAlignment="Center" Text="{Binding Metadata.Name}" />
    </StackPanel>
</UserControl>