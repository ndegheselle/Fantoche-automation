<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:workflows="clr-namespace:Automation.App.Features.Scoped.Workflows"
             xmlns:components="clr-namespace:Automation.App.Features.Scoped.Components"
             x:DataType="workflows:WorkflowVm"
             x:Class="Automation.App.Features.Scoped.Workflows.WorkflowPage">
    <StackPanel Margin="4" Spacing="8">
        <components:ElementHeader />
        <TextBlock Classes="Muted" Text="The workflow editor will be displayed here." />
    </StackPanel>
</UserControl>
