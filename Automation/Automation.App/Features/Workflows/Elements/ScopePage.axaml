<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:Automation.App.Features.Workflows.Components"
             xmlns:scoped="clr-namespace:Automation.Shared.Data.Scoped;assembly=Automation.Shared"
             x:DataType="scoped:Scope"
             x:Class="Automation.App.Features.Workflows.Elements.ScopePage">
    <StackPanel Margin="16" Spacing="8">
        <components:ElementHeader />
        <TextBlock Classes="Muted" Text="{Binding Childrens.Count, StringFormat='Contains {0} element(s).'}" />
    </StackPanel>
</UserControl>
