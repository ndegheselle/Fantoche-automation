<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:converters="clr-namespace:Automation.App.Converters"
             xmlns:scoped="clr-namespace:Automation.Shared.Data.Scoped;assembly=Automation.Shared"
             x:DataType="scoped:ScopedElement"
             x:Class="Automation.App.Features.Workflows.Elements.ElementHeader">
    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="LucideIcon"
                   FontSize="24" Width="24" Height="24"
                   Text="{Binding Metadata.Type, Converter={x:Static converters:ScopedTypeConverters.ToLucideIcon}}" />
        <TextBlock Classes="h4" VerticalAlignment="Center" Text="{Binding Metadata.Name}" />
        <shadui:Badge VerticalAlignment="Center" Content="{Binding Metadata.Type}" />
    </StackPanel>
</UserControl>
