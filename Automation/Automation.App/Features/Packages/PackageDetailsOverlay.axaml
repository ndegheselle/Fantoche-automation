<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:packages="clr-namespace:Automation.App.Features.Packages"
             xmlns:execution="clr-namespace:Automation.Shared.Data.Execution;assembly=Automation.Shared"
             x:DataType="packages:PackageDetailsVm"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Background="{DynamicResource BackgroundColor}"
             x:Class="Automation.App.Features.Packages.PackageDetailsOverlay">
    <Design.DataContext>
        <packages:PackageDetailsVMDesign />
    </Design.DataContext>
    <Panel Background="{DynamicResource CardBackgroundColor}">
        <Grid RowDefinitions="auto * *" RowSpacing="8" Margin="8">
            <Grid ColumnDefinitions="* auto">
                <StackPanel Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="LucideIcon"
                                   Text="{x:Static fonts:LucideIconFont.Package}" VerticalAlignment="Center" />
                        <TextBlock Classes="h4" Text="{Binding Package.Identifier.Id}" />
                    </StackPanel>
                    <TextBlock Classes="Caption"
                               Foreground="{DynamicResource MutedColor}"
                               Text="{Binding Package.Description}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="Ghost"
                        CornerRadius="{DynamicResource MdCornerRadius}"
                        Command="{Binding BackCommand}"
                        Content="Back to packages">
                    <shadui:ButtonAssist.Icon>
                        <TextBlock Classes="LucideIcon" Text="{x:Static fonts:LucideIconFont.ArrowLeft}" />
                    </shadui:ButtonAssist.Icon>
                </Button>
            </Grid>

            <DataGrid
                Grid.Row="1"
                x:Name="VersionsList"
                ItemsSource="{Binding Versions}"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                GridLinesVisibility="Horizontal"
                SelectionMode="Single"
                IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Version" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <shadui:Badge Content="{Binding }" HorizontalAlignment="Left" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Classes="DestructiveIcon"
                                        CornerRadius="{DynamicResource MdCornerRadius}"
                                        ToolTip.Tip="Remove"
                                        Command="{Binding #VersionsList.((packages:PackageDetailsVm)DataContext).RemoveVersionCommand}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Classes="LucideIcon"
                                               Text="{x:Static fonts:LucideIconFont.Trash}" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Panel Grid.Row="2">
                <Border IsVisible="{Binding IsEmpty}"
                        BorderBrush="{DynamicResource WarningColor20}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MdCornerRadius}">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Classes="LucideIcon"
                                   Foreground="{DynamicResource WarningColor}"
                                   VerticalAlignment="Center"
                                   Text="{x:Static fonts:LucideIconFont.AlertTriangle}" />
                        <TextBlock Text="No classes"
                                   Foreground="{DynamicResource WarningColor60}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <DataGrid
                    x:Name="ClassesList"
                    IsVisible="{Binding !IsEmpty}"
                    ItemsSource="{Binding GroupedClasses}"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    GridLinesVisibility="Horizontal"
                    SelectionMode="Single"
                    IsReadOnly="True">

                    <DataGrid.RowGroupTheme>
                        <ControlTheme TargetType="DataGridRowGroupHeader"
                                      BasedOn="{StaticResource {x:Type DataGridRowGroupHeader}}">
                            <Setter Property="IsItemCountVisible" Value="True" />
                        </ControlTheme>
                    </DataGrid.RowGroupTheme>

                    <DataGrid.Columns>
                        <DataGridTextColumn x:DataType="execution:ClassTarget" Header="Class" Width="*"
                                            Binding="{Binding ClassFullName}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Panel>


        </Grid>
        <shadui:BusyArea IsBusy="{Binding IsLoading}" />
    </Panel>
</UserControl>