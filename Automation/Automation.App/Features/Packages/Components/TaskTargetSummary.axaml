<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:execution="clr-namespace:Automation.Shared.Data.Execution;assembly=Automation.Shared"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="execution:PackageClassTarget"
             x:Class="Automation.App.Features.Packages.Components.TaskTargetSummary">
    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
            CornerRadius="{StaticResource LgCornerRadius}" Background="{DynamicResource CardBackgroundColor}"
            Padding="16,8">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Classes="h4" Text="{Binding Package.Id}" />
                <shadui:Badge Content="{Binding Package.Version}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding ClassFullName}" />
        </StackPanel>
    </Border>
</UserControl>