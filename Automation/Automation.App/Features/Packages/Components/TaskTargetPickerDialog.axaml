<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:data="clr-namespace:Automation.App.Components.Data"
             xmlns:inputs="clr-namespace:Automation.App.Components.Inputs"
             xmlns:components="clr-namespace:Automation.App.Features.Packages.Components"
             xmlns:execution="clr-namespace:Automation.Shared.Data.Execution;assembly=Automation.Shared"
             x:DataType="components:TaskTargetPickerVm"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="520"
             x:Class="Automation.App.Features.Packages.Components.TaskTargetPickerDialog">
    <Design.DataContext>
        <components:TaskTargetPickerVMDesign />
    </Design.DataContext>
    <Grid RowDefinitions="auto * auto" RowSpacing="8" Margin="16" Width="800" Height="520">
        <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Classes="LucideIcon" VerticalAlignment="Center"
                           Text="{x:Static fonts:LucideIconFont.Package}" />
                <TextBlock Classes="h4" VerticalAlignment="Center" Text="Select a task target" />
            </StackPanel>
            <TextBlock Classes="Caption"
                       Foreground="{DynamicResource MutedColor}"
                       Text="Pick a package, then one of its classes." />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="* 4 *" ColumnSpacing="2">
            <!-- Packages (master) -->
            <Grid Grid.Column="0" RowDefinitions="auto * auto" RowSpacing="4">
                <inputs:DebouncedSearch Grid.Row="0"
                                        Search="{Binding SearchText, Mode=TwoWay}" />

                <Panel Grid.Row="1">
                    <DataGrid
                        x:Name="PackagesList"
                        ItemsSource="{Binding Packages}"
                        SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                        CanUserReorderColumns="False"
                        CanUserSortColumns="False"
                        GridLinesVisibility="Horizontal"
                        SelectionMode="Single"
                        IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:DataType="execution:PackageInfos" Header="Identifier" Width="*"
                                                Binding="{Binding Identifier.Id}" />
                            <DataGridTemplateColumn Header="Version">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="execution:PackageInfos">
                                        <shadui:Badge Content="{Binding Identifier.Version}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <shadui:BusyArea IsBusy="{Binding IsLoadingPackages}" />
                </Panel>

                <data:Pagination
                    Grid.Row="2"
                    Total="{Binding TotalItems}"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    PageSize="{Binding PageSize, Mode=TwoWay}" />
            </Grid>
            
            <GridSplitter Grid.Column="1" Background="{DynamicResource GhostColor}" />
            
            <!-- Classes (detail) -->
            <Panel Grid.Column="2">
                <Border IsVisible="{Binding !HasSelectedPackage}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MdCornerRadius}">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Classes="LucideIcon"
                                   Foreground="{DynamicResource MutedColor}"
                                   VerticalAlignment="Center"
                                   Text="{x:Static fonts:LucideIconFont.ArrowLeft}" />
                        <TextBlock Text="Select a package"
                                   Foreground="{DynamicResource MutedColor}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding IsClassesEmpty}"
                        BorderBrush="{DynamicResource WarningColor20}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MdCornerRadius}">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Classes="LucideIcon"
                                   Foreground="{DynamicResource WarningColor}"
                                   VerticalAlignment="Center"
                                   Text="{x:Static fonts:LucideIconFont.AlertTriangle}" />
                        <TextBlock Text="No classes"
                                   Foreground="{DynamicResource WarningColor60}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <DataGrid
                    x:Name="ClassesList"
                    IsVisible="{Binding HasSelectedPackage}"
                    ItemsSource="{Binding GroupedClasses}"
                    SelectedItem="{Binding SelectedClass, Mode=TwoWay}"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    GridLinesVisibility="Horizontal"
                    SelectionMode="Single"
                    IsReadOnly="True">

                    <DataGrid.RowGroupTheme>
                        <ControlTheme TargetType="DataGridRowGroupHeader"
                                      BasedOn="{StaticResource {x:Type DataGridRowGroupHeader}}">
                            <Setter Property="IsItemCountVisible" Value="True" />
                        </ControlTheme>
                    </DataGrid.RowGroupTheme>

                    <DataGrid.Columns>
                        <DataGridTextColumn x:DataType="execution:ClassTarget" Header="Class" Width="*"
                                            Binding="{Binding ClassFullName}" />
                    </DataGrid.Columns>
                </DataGrid>

                <shadui:BusyArea IsBusy="{Binding IsLoadingClasses}" />
            </Panel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Outline" Content="Cancel" Command="{Binding CancelCommand}" />
            <Button Classes="Primary" Content="Select" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
