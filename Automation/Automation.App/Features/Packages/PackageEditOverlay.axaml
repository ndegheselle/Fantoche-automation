<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:packages="clr-namespace:Automation.App.Features.Packages"
             x:DataType="packages:PackageEditVM"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Automation.App.Features.Packages.PackageEditOverlay">
    <Grid RowDefinitions="auto *" Margin="4" RowSpacing="2" Background="{DynamicResource BackgroundColor}">
        <Button Grid.Column="2" Command="{Binding Close}" Classes="Secondary" HorizontalAlignment="Left">
            <shadui:ButtonAssist.Icon>
                <TextBlock Margin="0,0,4,0" Classes="LucideIcon" Text="{x:Static fonts:LucideIconFont.ArrowLeft}" />
            </shadui:ButtonAssist.Icon>
            Back to packages
        </Button>
        <TextBlock Grid.Row="1">Fafa fafa</TextBlock>
    </Grid>
</UserControl>
