<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:data="clr-namespace:Automation.App.Components.Data"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:inputs="clr-namespace:Automation.App.Components.Inputs"
             xmlns:packages="clr-namespace:Automation.App.Features.Packages"
             x:DataType="packages:PackagesPageVM"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="450"
             x:Class="Automation.App.Features.Packages.PackagesPage">
    <Grid RowDefinitions="auto * auto Auto" RowSpacing="2" Margin="4">
        <Grid ColumnDefinitions="*" ColumnSpacing="2">
            <inputs:DebouncedSearch Grid.Column="0"
                                    Search="{Binding SearchText, Mode=TwoWay}" />
        </Grid>

        <Panel Grid.Row="1">
            <DataGrid
                x:Name="PackagesList"
                ItemsSource="{Binding GroupedItems}"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                GridLinesVisibility="Horizontal"
                SelectionMode="Single"
                IsReadOnly="True">

                <DataGrid.RowGroupTheme>
                    <ControlTheme TargetType="DataGridRowGroupHeader" BasedOn="{StaticResource {x:Type DataGridRowGroupHeader}}">
                        <Setter Property="IsItemCountVisible" Value="True" />
                    </ControlTheme>
                </DataGrid.RowGroupTheme>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Version" Binding="{Binding Identifier.Version}" />
                    <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}" />
                    <DataGridTemplateColumn CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Classes="Icon Destructive"
                                        CornerRadius="{DynamicResource MdCornerRadius}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Remove"
                                        Command="{Binding #PackagesList.((packages:PackagesPageVM)DataContext).RemoveCommand}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Classes="LucideIcon"
                                               Text="{x:Static fonts:LucideIconFont.Trash}" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <shadui:BusyArea IsBusy="{Binding IsLoading}" />
        </Panel>

        <inputs:FilePicker Grid.Row="2"
                           Margin="0,4,0,0"
                           FileFormat="*.nupkg"
                           Description="Add new packages (.nupkg)"
                           Command="{Binding AddPackagesCommand}" />

        <data:Pagination Grid.Row="3"
                         Total="{Binding TotalItems}"
                         CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                         PageSize="{Binding PageSize, Mode=TwoWay}" />
    </Grid>
</UserControl>