<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:data="clr-namespace:Automation.App.Components.Data"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:inputs="clr-namespace:Automation.App.Components.Inputs"
             xmlns:packages="clr-namespace:Automation.App.Features.Packages"
             xmlns:execution="clr-namespace:Automation.Shared.Data.Execution;assembly=Automation.Shared"
             x:DataType="packages:PackagesPageVM"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="450"
             x:Class="Automation.App.Features.Packages.PackagesPage">
    <Design.DataContext>
        <packages:PackagesPageVMDesign />
    </Design.DataContext>
    <Grid RowDefinitions="auto * auto auto" RowSpacing="4" Margin="4">
        <inputs:DebouncedSearch Grid.Row="0"
                                Search="{Binding SearchText, Mode=TwoWay}" />

        <Panel Grid.Row="1">
            <DataGrid
                x:Name="PackagesList"
                ItemsSource="{Binding GroupedItems}"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                GridLinesVisibility="Horizontal"
                SelectionMode="Single"
                IsReadOnly="True">

                <DataGrid.RowGroupTheme>
                    <ControlTheme TargetType="DataGridRowGroupHeader"
                                  BasedOn="{StaticResource {x:Type DataGridRowGroupHeader}}">
                        <Setter Property="IsItemCountVisible" Value="True" />
                    </ControlTheme>
                </DataGrid.RowGroupTheme>

                <DataGrid.Columns>
                    <DataGridTextColumn x:DataType="execution:PackageInfos" Header="Version"
                                        Binding="{Binding Identifier.Version}" />
                    <DataGridTextColumn x:DataType="execution:PackageInfos" Header="Description" Width="*"
                                        Binding="{Binding Description}" />
                    <DataGridTemplateColumn CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    
                                    <Button Classes="Icon"
                                            CornerRadius="{DynamicResource MdCornerRadius}"
                                            ToolTip.Tip="Details">
                                        <TextBlock Classes="LucideIcon"
                                                   Text="{x:Static fonts:LucideIconFont.Eye}" />
                                    </Button>
                                    <Button Classes="DestructiveIcon"
                                            CornerRadius="{DynamicResource MdCornerRadius}"
                                            ToolTip.Tip="Remove"
                                            Command="{Binding #PackagesList.((packages:PackagesPageVM)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Classes="LucideIcon"
                                                   Text="{x:Static fonts:LucideIconFont.Trash}" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <shadui:BusyArea IsBusy="{Binding IsLoading}" />
        </Panel>

        <data:Pagination
            Grid.Row="2"
            Total="{Binding TotalItems}"
            CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
            PageSize="{Binding PageSize, Mode=TwoWay}" />

        <inputs:FilePicker
            Grid.Row="3"
            FileFormat="*.nupkg"
            Description="Add new packages (.nupkg)"
            Command="{Binding AddPackagesCommand}" />

    </Grid>
</UserControl>