<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             xmlns:data="clr-namespace:Automation.App.Components.Data"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:inputs="clr-namespace:Automation.App.Components.Inputs"
             xmlns:packages="clr-namespace:Automation.App.Features.Packages"
             x:DataType="packages:PackagesPageViewModel"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="450"
             x:Class="Automation.App.Features.Packages.PackagesPage">
    <Grid RowDefinitions="auto * Auto" RowSpacing="2" Margin="4">
        <Grid ColumnDefinitions="* auto" ColumnSpacing="2">
            <inputs:DebouncedSearch Grid.Column="0"
                                    Search="{Binding SearchText, Mode=TwoWay}" />
            <Button Grid.Column="1" Classes="Outline" Command="{Binding AddCommand}">
                <shadui:ButtonAssist.Icon>
                    <TextBlock Margin="0,0,4,0" Classes="LucideIcon" Text="{x:Static fonts:LucideIconFont.Plus}" />
                </shadui:ButtonAssist.Icon>
                Add
            </Button>
        </Grid>

        <DataGrid Grid.Row="1"
                  x:Name="PackagesList"
                  ItemsSource="{Binding Items}"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Identifier.Identifier}" />
                <DataGridTextColumn Header="Last version" Binding="{Binding Identifier.Version}" />
                <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}" />
                <DataGridTemplateColumn CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <shadui:SimpleDropdown
                                Classes="Icon Grid"
                                CornerRadius="{DynamicResource MdCornerRadius}"
                                HorizontalAlignment="Center"
                                PopupPlacement="BottomEdgeAlignedLeft"
                                PopupWidth="190"
                                VerticalAlignment="Center">
                                <shadui:SimpleDropdown.TriggerContent>
                                    <TextBlock Margin="0,0,4,0" Classes="LucideIcon"
                                               Text="{x:Static fonts:LucideIconFont.Ellipsis}" />
                                </shadui:SimpleDropdown.TriggerContent>
                                <shadui:SimpleDropdown.MenuLabel>
                                    <TextBlock Classes="Caption Muted" Text="Actions" />
                                </shadui:SimpleDropdown.MenuLabel>
                                <Separator />
                                <Button Command="{Binding #PackagesList.((packages:PackagesPageViewModel)DataContext).EditCommand}"
                                        CommandParameter="{Binding}">
                                    <shadui:ButtonAssist.Icon>
                                        <TextBlock Margin="0,0,4,0" Classes="LucideIcon"
                                                   Text="{x:Static fonts:LucideIconFont.Edit}" />
                                    </shadui:ButtonAssist.Icon>
                                    Edit
                                </Button>
                                <Button Classes="Destructive"
                                        Command="{Binding #PackagesList.((packages:PackagesPageViewModel)DataContext).RemoveCommand }"
                                        CommandParameter="{Binding}">
                                    <shadui:ButtonAssist.Icon>
                                        <TextBlock Margin="0,0,4,0" Classes="LucideIcon"
                                                   Text="{x:Static fonts:LucideIconFont.Trash}" />
                                    </shadui:ButtonAssist.Icon>
                                    Remove
                                </Button>
                            </shadui:SimpleDropdown>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <data:Pagination Grid.Row="2"
                         Total="{Binding TotalItems}"
                         CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                         PageSize="{Binding PageSize, Mode=TwoWay}" />
    </Grid>
</UserControl>