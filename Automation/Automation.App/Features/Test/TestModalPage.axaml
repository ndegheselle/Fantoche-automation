<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="240"
             xmlns:test="clr-namespace:Automation.App.Features.Test"
             x:DataType="test:TestModalViewModel"
             x:Class="Automation.App.Features.Test.TestModalPage">
    <Border Background="{DynamicResource Background}"
            BorderBrush="{DynamicResource BorderColor30}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24"
            MinWidth="420"
            MinHeight="160">
        <StackPanel Spacing="16">
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="This is a modal page displayed on top of the current page."
                       TextWrapping="Wrap"
                       Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Command="{Binding OpenNestedModalCommand}">Open Nested Modal</Button>
                <Button Command="{Binding CloseCommand}">Close</Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
