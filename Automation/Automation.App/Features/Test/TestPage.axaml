<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:test="clr-namespace:Automation.App.Features.Test"
               x:DataType="test:TestViewModel"
             x:Class="Automation.App.Features.Test.TestPage">
    <StackPanel Spacing="8" Margin="16">
        <TextBlock Text="{Binding Tata}" />
        <Button Command="{Binding TestToastCommand}">Toast</Button>
        <Button Command="{Binding OpenModalCommand}">Open Modal</Button>
    </StackPanel>
</UserControl>
