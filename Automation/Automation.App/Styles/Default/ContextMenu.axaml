<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme TargetType="ContextMenu" x:Key="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource LgCornerRadius}" />
        <Setter Property="Padding" Value="0,2" />
        <Setter Property="WrapPanel.Orientation" Value="Vertical" />
        <Setter Property="Template">
            <ControlTemplate>
                <LayoutTransformControl Name="LayoutTransform" RenderTransformOrigin="0%, 0%">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BoxShadow="{DynamicResource Shadow}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        shadui:ScrollEventAssist.PreventScrollPropagation="True">
                        <ScrollViewer>
                            <ItemsPresenter
                                Grid.IsSharedSizeScope="True"
                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                KeyboardNavigation.TabNavigation="Continue"
                                Name="PART_ItemsPresenter" />
                        </ScrollViewer>
                    </Border>
                </LayoutTransformControl>
            </ControlTemplate>
        </Setter>

        <!-- Open scale + fade animation, matching the ShadUI Menu popup -->
        <Style Selector="^[IsOpen=True] /template/ LayoutTransformControl#LayoutTransform">
            <Style.Animations>
                <Animation Duration="0:0:0.18" Easing="{StaticResource EaseOut}" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleX" Value="0.97" />
                        <Setter Property="ScaleTransform.ScaleY" Value="0.97" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </ControlTheme>
</ResourceDictionary>
