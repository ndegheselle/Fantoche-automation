<UserControl
    x:Class="Automation.App.Views.WorkersPages.WorkerMainPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkersPages"
    x:DataType="vm:WorkerMainPageViewModel">
    <Grid Margin="8" RowDefinitions="* *" RowSpacing="8">
        <Border
            Grid.Row="0"
            Padding="12"
            CornerRadius="{DynamicResource MdCornerRadius}"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderColor30}">
            <StackPanel Spacing="6">
                <TextBlock Classes="h4" Text="Status" />
                <TextBlock Foreground="{DynamicResource MutedColor}"
                           Text="List of workers with status, available slots and last task status." />
            </StackPanel>
        </Border>
        <Border
            Grid.Row="1"
            Padding="12"
            CornerRadius="{DynamicResource MdCornerRadius}"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderColor30}">
            <StackPanel Spacing="6">
                <TextBlock Classes="h4" Text="Scheduler" />
                <TextBlock Foreground="{DynamicResource MutedColor}"
                           Text="Show all tasks scheduled for all servers." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
