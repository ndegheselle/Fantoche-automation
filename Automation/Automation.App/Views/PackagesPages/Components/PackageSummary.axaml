<UserControl
    x:Class="Automation.App.Views.PackagesPages.Components.PackageSummary"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Automation.App.Views.PackagesPages.Components"
    x:Name="Root"
    x:DataType="local:PackageSummary">
    <Border
        Padding="8"
        CornerRadius="{DynamicResource MdCornerRadius}"
        BorderThickness="1"
        BorderBrush="{DynamicResource BorderColor30}">
        <Grid DataContext="{Binding #Root.Package}" ColumnDefinitions="* Auto" RowDefinitions="Auto Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="Bold" Text="{Binding Identifier.Identifier}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Classes="Caption" Text="{Binding Identifier.Version}" />
            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Classes="Caption" Text="{Binding Description}" TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
