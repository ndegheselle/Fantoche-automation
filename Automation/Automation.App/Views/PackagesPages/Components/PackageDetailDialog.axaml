<UserControl
    x:Class="Automation.App.Views.PackagesPages.Components.PackageDetailDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.PackagesPages.Components"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:exec="clr-namespace:Automation.Shared.Data.Execution;assembly=Automation.Shared"
    x:DataType="vm:PackageDetailDialogViewModel"
    MinWidth="420">
    <StackPanel Margin="24" Spacing="12">
        <TextBlock Classes="h4" Text="Select class" />
        <TextBlock Text="{Binding Package.Description}" TextWrapping="Wrap" />

        <Grid ColumnDefinitions="Auto *">
            <TextBlock Grid.Column="0" Classes="Bold" VerticalAlignment="Center" Text="Versions" />
            <ComboBox
                Grid.Column="1"
                Margin="8,0,0,0"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding Versions}"
                SelectedItem="{Binding SelectedVersion, Mode=TwoWay}" />
        </Grid>

        <Panel Height="220">
            <ListBox
                ItemsSource="{Binding Classes}"
                SelectedItem="{Binding SelectedClass, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="exec:ClassTarget">
                        <TextBlock Text="{Binding ClassFullName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel
                IsVisible="{Binding !Classes.Count}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="4">
                <lucide:LucideIcon Kind="CircleQuestionMark" Size="24" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource MutedColor}" />
                <TextBlock Text="No compatible classes found." Foreground="{DynamicResource MutedColor}" />
            </StackPanel>
        </Panel>

        <Grid ColumnDefinitions="* Auto Auto">
            <Button Grid.Column="0" Classes="Outline Destructive" HorizontalAlignment="Left" Command="{Binding DeleteVersionCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Trash2" Size="14" />
                    <TextBlock Text="{Binding SelectedVersion, StringFormat='Delete v{0}'}" />
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Classes="Outline" Margin="0,0,8,0" Command="{Binding CancelCommand}">
                <TextBlock Text="Cancel" />
            </Button>
            <Button Grid.Column="2" Classes="Primary" Command="{Binding SelectCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Check" Size="14" />
                    <TextBlock Text="Select class" />
                </StackPanel>
            </Button>
        </Grid>
    </StackPanel>
</UserControl>
