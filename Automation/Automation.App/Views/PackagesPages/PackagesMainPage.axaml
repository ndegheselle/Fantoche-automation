<UserControl
    x:Class="Automation.App.Views.PackagesPages.PackagesMainPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.PackagesPages"
    xmlns:components="clr-namespace:Automation.App.Views.PackagesPages.Components"
    xmlns:ctrl="clr-namespace:Automation.App.Controls"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:exec="clr-namespace:Automation.Shared.Data.Execution;assembly=Automation.Shared"
    x:DataType="vm:PackagesMainPageViewModel">
    <Grid Margin="8" RowDefinitions="Auto * Auto">
        <Grid Grid.Row="0" ColumnDefinitions="* Auto">
            <TextBox Grid.Column="0" Text="{Binding SearchText, Mode=TwoWay}" Watermark="Search packages…" />
            <Button Grid.Column="1" Margin="4,0,0,0" Classes="Primary" Command="{Binding AddCommand}" ToolTip.Tip="Add package">
                <lucide:LucideIcon Kind="Plus" Size="16" />
            </Button>
        </Grid>

        <ListBox
            Grid.Row="1"
            Margin="0,8"
            ItemsSource="{Binding Packages}"
            DoubleTapped="PackageList_DoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="exec:PackageInfos">
                    <components:PackageSummary Package="{Binding}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ctrl:Paging
            Grid.Row="2"
            HorizontalAlignment="Left"
            Total="{Binding Total}"
            PageNumber="{Binding Page, Mode=TwoWay}"
            Capacity="{Binding PageSize, Mode=TwoWay}"
            PagingChange="Paging_PagingChange" />
    </Grid>
</UserControl>
