<UserControl
    x:Class="Automation.App.Views.WorkPages.Components.MetadataEdit"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Automation.App.Views.WorkPages.Components"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    x:Name="Root"
    x:DataType="local:MetadataEdit">
    <!-- Inner content binds to the control; the control's own DataContext stays inherited so
         Metadata="{Binding ...}" resolves against the parent. -->
    <StackPanel DataContext="{Binding #Root}" Spacing="8">
        <Grid ColumnDefinitions="* Auto" RowDefinitions="Auto Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Margin="0,0,0,2" />
            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Metadata.Name, Mode=TwoWay}" />

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                <Button Classes="Ghost" Padding="6" Click="ButtonEditColor_Click" ToolTip.Tip="Color">
                    <lucide:LucideIcon Kind="Palette" Size="16" />
                </Button>
                <Button Classes="Ghost" Padding="6" Click="ButtonEditIcon_Click" ToolTip.Tip="Icon">
                    <lucide:LucideIcon Kind="Pencil" Size="16" />
                </Button>
            </StackPanel>
            <local:ScopedIcon Grid.Row="1" Grid.Column="1" Metadata="{Binding Metadata}" Size="18" HorizontalAlignment="Center" />
        </Grid>

        <TextBlock Text="Tags" Margin="0,4,0,2" />
        <ItemsControl ItemsSource="{Binding Metadata.Tags}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Margin="0,0,4,4" Padding="6,2" CornerRadius="4" Background="{DynamicResource MutedColor}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                            <Button Classes="Ghost" Padding="2" Click="RemoveTag_Click">
                                <lucide:LucideIcon Kind="X" Size="10" />
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Grid ColumnDefinitions="* Auto">
            <TextBox x:Name="NewTagBox" Grid.Column="0" Watermark="Add tag…" />
            <Button Grid.Column="1" Margin="4,0,0,0" Click="AddTag_Click" Content="Add" />
        </Grid>
    </StackPanel>
</UserControl>
