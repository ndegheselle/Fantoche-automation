<UserControl
    x:Class="Automation.App.Views.WorkPages.Scopes.ScopePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkPages.Scopes"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    x:DataType="vm:ScopePageViewModel">
    <Grid>
        <TabControl>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <lucide:LucideIcon Kind="Clock" Size="16" />
                        <TextBlock Text="Execution History" />
                    </StackPanel>
                </TabItem.Header>
                <vm:ScopeHistory Scope="{Binding Scope.Model}" />
            </TabItem>
        </TabControl>
        <Button
            Command="{Binding OpenSettingsCommand}"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,4,4,0"
            Classes="Ghost"
            Padding="6"
            ToolTip.Tip="Scope settings">
            <lucide:LucideIcon Kind="Settings" Size="16" />
        </Button>
    </Grid>
</UserControl>
