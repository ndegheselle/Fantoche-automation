<UserControl
    x:Class="Automation.App.Views.WorkPages.Scopes.Components.ScopedBreadcrumb"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkPages.Scopes.Components"
    xmlns:components="clr-namespace:Automation.App.Views.WorkPages.Components"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:scoped="clr-namespace:Automation.Shared.Data.Scoped;assembly=Automation.Shared"
    x:Name="Root"
    x:DataType="vm:ScopedBreadcrumbViewModel">
    <ItemsControl ItemsSource="{Binding Parents}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="scoped:Scope">
                <StackPanel Orientation="Horizontal">
                    <lucide:LucideIcon
                        Kind="ChevronRight"
                        Size="8"
                        VerticalAlignment="Center"
                        Margin="4,0" />
                    <Button
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4,2"
                        Cursor="Hand"
                        Click="ButtonScope_Click">
                        <StackPanel Orientation="Horizontal">
                            <components:ScopedIcon Metadata="{Binding Metadata}" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding Metadata.Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
