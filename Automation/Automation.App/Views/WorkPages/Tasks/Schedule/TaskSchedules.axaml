<UserControl
    x:Class="Automation.App.Views.WorkPages.Tasks.Schedules.TaskSchedules"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkPages.Tasks.Schedules"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:data="clr-namespace:Automation.Shared.Data;assembly=Automation.Shared"
    x:DataType="vm:TaskSchedulesViewModel">
    <Grid Margin="8" RowDefinitions="Auto *">
        <Grid Grid.Row="0" ColumnDefinitions="* Auto">
            <TextBlock Grid.Column="0" Classes="h4" Text="Schedules" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <Button Classes="Ghost" Padding="6" Command="{Binding EditScheduleCommand}" ToolTip.Tip="Edit">
                    <lucide:LucideIcon Kind="Pencil" Size="14" />
                </Button>
                <Button Classes="Ghost Destructive" Padding="6" Command="{Binding RemoveScheduleCommand}" ToolTip.Tip="Remove">
                    <lucide:LucideIcon Kind="Trash2" Size="14" />
                </Button>
                <Button Classes="Primary" Padding="6" Command="{Binding AddScheduleCommand}" ToolTip.Tip="Add">
                    <lucide:LucideIcon Kind="Plus" Size="14" />
                </Button>
            </StackPanel>
        </Grid>

        <ListBox
            Grid.Row="1"
            Margin="0,8,0,0"
            ItemsSource="{Binding Schedules}"
            SelectedItem="{Binding Selected, Mode=TwoWay}"
            DoubleTapped="ScheduleList_DoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="data:Schedule">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <lucide:LucideIcon Kind="Calendar" Size="14" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CronExpression}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
