<UserControl
    x:Class="Automation.App.Views.WorkPages.Tasks.TaskHistory"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkPages.Tasks"
    xmlns:instances="clr-namespace:Automation.App.Views.WorkPages.Tasks.Instances"
    xmlns:ctrl="clr-namespace:Automation.App.Controls"
    x:DataType="vm:TaskHistoryViewModel">
    <Grid RowDefinitions="* Auto">
        <instances:TaskInstanceList Grid.Row="0" Instances="{Binding Instances}" />
        <ctrl:Paging
            Grid.Row="1"
            Margin="8,4"
            HorizontalAlignment="Left"
            Total="{Binding Total}"
            PageNumber="{Binding Page, Mode=TwoWay}"
            Capacity="{Binding PageSize, Mode=TwoWay}"
            PagingChange="Paging_PagingChange" />
    </Grid>
</UserControl>
