<UserControl
    x:Class="Automation.App.Views.WorkPages.Tasks.TaskEditDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkPages.Tasks"
    xmlns:components="clr-namespace:Automation.App.Views.WorkPages.Components"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    x:DataType="vm:TaskEditDialogViewModel"
    MinWidth="320">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock Classes="h4" Text="Task settings" />
        <components:MetadataEdit Metadata="{Binding Metadata}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Outline" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="X" Size="14" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button Classes="Primary" Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Save" Size="14" />
                    <TextBlock Text="Save changes" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
