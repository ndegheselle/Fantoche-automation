<UserControl
    x:Class="Automation.App.Views.WorkPages.TasksMainPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Views.WorkPages"
    xmlns:scopes="clr-namespace:Automation.App.Views.WorkPages.Scopes.Components"
    x:DataType="vm:TasksMainPageViewModel">
    <Grid RowDefinitions="Auto *">
        <!-- Breadcrumb of the current scope. -->
        <scopes:ScopedBreadcrumb
            x:Name="Breadcrumb"
            Grid.Row="0"
            Margin="4"
            Scope="{Binding CurrentScope}"
            ScopeSelected="Breadcrumb_ScopeSelected" />

        <Grid Grid.Row="1" ColumnDefinitions="200 Auto *">
            <scopes:ScopedSelector
                x:Name="Selector"
                Grid.Column="0"
                SelectionChanged="Selector_SelectionChanged"
                CurrentScopeChanged="Selector_CurrentScopeChanged" />
            <GridSplitter Grid.Column="1" Width="2" ResizeDirection="Columns" />
            <ContentControl Grid.Column="2" Content="{Binding Content}" />
        </Grid>
    </Grid>
</UserControl>
