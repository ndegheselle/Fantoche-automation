<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.App.App"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="LucideIcon">avares://Automation.App/Assets/Fonts#lucide</FontFamily>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Automation.App/Styles/ContextMenu.axaml" />
                <ResourceInclude Source="avares://Automation.App/Styles/Flyout.axaml" />
                <ResourceInclude Source="avares://Automation.App/Styles/TreeView.axaml" />
                <ResourceInclude Source="avares://Automation.App/Styles/ListBox.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <shadui:ShadTheme />
        <StyleInclude Source="avares://Automation.App/Styles/Index.axaml" />
    </Application.Styles>
</Application>