<UserControl
    x:Class="Automation.App.Components.Inputs.SelectIconDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Components.Inputs"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
    x:DataType="vm:SelectIconDialogViewModel"
    Width="420">
    <StackPanel Margin="24" Spacing="12">
        <TextBlock Classes="h4" Text="Select icon" />
        <TextBox
            Text="{Binding SearchText, Mode=TwoWay}"
            Watermark="Search…"
            shadui:ControlAssist.Label="Search" />
        <ListBox
            Height="360"
            ItemsSource="{Binding Icons}"
            SelectedItem="{Binding Selected, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:IconItem">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <lucide:LucideIcon Kind="{Binding Kind}" Size="18" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Outline" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="X" Size="14" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button Classes="Primary" Command="{Binding ValidateCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Check" Size="14" />
                    <TextBlock Text="Select" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
