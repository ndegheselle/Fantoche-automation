<UserControl
    x:Class="Automation.App.Components.Inputs.FilePickerDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Components.Inputs"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
    x:DataType="vm:FilePickerDialogViewModel"
    MinWidth="360">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock Classes="h4" Text="{Binding Title}" />
        <TextBlock Text="{Binding SubTitle}" TextWrapping="Wrap" IsVisible="{Binding SubTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <Grid ColumnDefinitions="* Auto">
            <TextBox
                Grid.Column="0"
                Text="{Binding FilePath, Mode=TwoWay}"
                Watermark="No file selected"
                shadui:ControlAssist.Label="File" />
            <Button
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Bottom"
                Click="Browse_Click"
                Content="Browse…" />
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Outline" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="X" Size="14" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button Classes="Primary" Command="{Binding ValidateCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Check" Size="14" />
                    <TextBlock Text="Ok" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
