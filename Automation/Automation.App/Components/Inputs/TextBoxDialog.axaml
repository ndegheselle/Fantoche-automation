<UserControl
    x:Class="Automation.App.Components.Inputs.TextBoxDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Components.Inputs"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
    x:DataType="vm:TextBoxDialogViewModel"
    MinWidth="280">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock Classes="h4" Text="{Binding Title}" />
        <TextBox
            Text="{Binding Value, Mode=TwoWay}"
            shadui:ControlAssist.Label="{Binding SubTitle}" />
        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Spacing="8">
            <Button Classes="Outline" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="X" Size="14" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button Classes="Primary" Command="{Binding ValidateCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Check" Size="14" />
                    <TextBlock Text="Ok" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
