<UserControl
    x:Class="Automation.App.Components.Inputs.SelectColorDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Automation.App.Components.Inputs"
    xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
    x:DataType="vm:SelectColorDialogViewModel"
    MinWidth="280">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock Classes="h4" Text="Select color" />
        <ColorPicker Color="{Binding SelectedColor, Mode=TwoWay}" HorizontalAlignment="Center" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Outline" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="X" Size="14" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button Classes="Primary" Command="{Binding ValidateCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <lucide:LucideIcon Kind="Check" Size="14" />
                    <TextBlock Text="Select" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
