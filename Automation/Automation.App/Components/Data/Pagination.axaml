<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:fonts="clr-namespace:Automation.App.Assets.Fonts"
             x:Class="Automation.App.Components.Data.Pagination"
             x:Name="ContainerElement">
    <Grid ColumnDefinitions="auto * auto auto" ColumnSpacing="2" DataContext="{Binding ElementName=ContainerElement}">
        <ComboBox x:Name="PageSizeBox"
                  ItemsSource="{Binding PageSizes}"
                  SelectedItem="{Binding PageSize, Mode=TwoWay}" />

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Text="{Binding RangeText}" />

        <Button Grid.Column="2" Classes="Outline"
                Click="OnPrevious"
                IsEnabled="{Binding HasPrevious}">
            <shadui:ButtonAssist.Icon>
                <TextBlock Margin="0,0,4,0" Classes="LucideIcon" Text="{x:Static fonts:LucideIconFont.ChevronLeft}" />
            </shadui:ButtonAssist.Icon>
            Previous
        </Button>
        <Button Grid.Column="3" Classes="Outline"
                Click="OnNext"
                IsEnabled="{Binding HasNext}">
            <shadui:ButtonAssist.Icon>
                <TextBlock Margin="0,0,4,0" Classes="LucideIcon" Text="{x:Static fonts:LucideIconFont.ChevronRight}" />
            </shadui:ButtonAssist.Icon>
            Next
        </Button>
    </Grid>
</UserControl>